#!/bin/bash
# Ephyr Live Audit Stream
# Run this ON the broker host to watch real-time events
# Usage: ./ephyr-live.sh [/path/to/audit.json]

AUDIT_LOG="${1:-/var/log/ephyr/audit.json}"

if [ ! -f "$AUDIT_LOG" ]; then
    echo "Audit log not found: $AUDIT_LOG"
    echo "Usage: $0 [/path/to/audit.json]"
    exit 1
fi

clear
echo "============================================"
echo "  EPHYR LIVE AUDIT STREAM"
echo "  Host: $(hostname)"
echo "  Log:  $AUDIT_LOG"
echo "  $(date '+%Y-%m-%d %H:%M:%S')"
echo "============================================"
echo ""

tail -f "$AUDIT_LOG" | python3 -c "
import sys, json
from datetime import datetime

COLORS = {
    'INFO': '\033[36m',
    'WARN': '\033[33m',
    'CRIT': '\033[31m',
    'ERR':  '\033[31m',
}
RESET = '\033[0m'
DIM = '\033[2m'
BOLD = '\033[1m'

EVENT_ICONS = {
    'mcp_exec':          'EXEC',
    'http_proxy':        'HTTP',
    'mcp_federation':    'MCP ',
    'task_create':       'TASK+',
    'task_delegate':     'DELE',
    'task_revoke':       'REVK',
    'task_bind':         'BIND',
    'command_denied':    'DENY',
    'auto_revoke':       'KILL',
    'request_denied':    'DENY',
    'cert_issued':       'CERT',
    'cert_revoked':      'XCER',
    'policy_reload':     'LOAD',
    'host_toggle':       'TOGL',
    'service_toggle':    'TOGL',
    'terminal_open':     'TERM',
    'terminal_close':    'TERM',
}

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
    except:
        continue

    sev = e.get('severity', 'INFO')[:4].upper()
    evt = e.get('event_type', '?')
    agent = e.get('agent', '-')
    ts = e.get('timestamp', '')
    details = e.get('details', {})

    try:
        t = datetime.fromisoformat(ts.replace('Z', '+00:00'))
        time_str = t.strftime('%H:%M:%S')
    except:
        time_str = '??:??:??'

    color = COLORS.get(sev, '')
    icon = EVENT_ICONS.get(evt, evt[:4].upper())

    parts = []
    for k, v in list(details.items())[:4]:
        if k in ('duration_ms',):
            parts.append(f'{v}ms')
        elif k == 'status_code':
            parts.append(f'HTTP {v}')
        elif k == 'cascade_count':
            parts.append(f'cascade={v}')
        else:
            parts.append(f'{k}={v}')
    detail_str = '  '.join(parts) if parts else ''

    print(f'{DIM}{time_str}{RESET} {color}{BOLD}{icon:5s}{RESET} {color}{sev:4s}{RESET}  {agent:12s} {detail_str}')
    sys.stdout.flush()
"
